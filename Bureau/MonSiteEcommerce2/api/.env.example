FLASK_ENV=development
FLASK_DEBUG=1
JWT_SECRET_KEY=change-this-to-a-long-random-secret-in-production

# ── Base de données ───────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///afromarket.db
# En production (Render la fournit automatiquement) :
# DATABASE_URL=postgresql://user:password@host:5432/afromarket

# ── CORS ──────────────────────────────────────────────────────────────────────
# Laisser vide en dev (autorise localhost automatiquement)
CORS_ORIGINS=
# En production : URL exacte du frontend Vercel
# CORS_ORIGINS=https://afromarket.vercel.app

# ── Cloudinary (stockage images en production) ────────────────────────────────
# Option 1 — URL complète (dashboard Cloudinary → "API Environment variable")
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# Option 2 — variables séparées
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# ── Email reset de mot de passe ───────────────────────────────────────────────
# Laisser vide en dev (le token est retourné dans la réponse API)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=ton@gmail.com
# SMTP_PASS=mot-de-passe-application-google
# SMTP_FROM=AfroMarket <noreply@afromarket.com>

# ── URL du site (pour les liens dans les emails) ──────────────────────────────
SITE_URL=http://localhost:5173
# En production :
# SITE_URL=https://afromarket.vercel.app
